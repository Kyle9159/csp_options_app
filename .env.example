# ===========================================
# CSP Options App — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ===========================================

# -------------------------------------------
# SCHWAB API CREDENTIALS (REQUIRED)
# Get these from https://developer.schwab.com
# → My Apps → your app → App Keys
# -------------------------------------------
SCHWAB_API_KEY=your_schwab_api_key_here
SCHWAB_APP_SECRET=your_schwab_app_secret_here

# Callback URL — must exactly match the value registered in the Schwab
# Developer Portal under "Callback URL" (no trailing slash).
REDIRECT_URI=https://127.0.0.1:8182

# -------------------------------------------
# SCHWAB ACCOUNT IDs (REQUIRED for positions)
# Find these at: https://127.0.0.1:5000/api/accounts
# after a successful Schwab login, or in the
# Schwab developer portal response explorer.
# -------------------------------------------
PAPER_ACCOUNT_ID=your_paper_account_id
LIVE_ACCOUNT_ID=your_live_account_id

# Set to True to trade paper account, False for live
PAPER_TRADING=True

# -------------------------------------------
# SCHWAB TOKEN STORAGE (OPTIONAL)
# Where the OAuth token is saved on disk.
# Default: cache_files/schwab_token.json
# -------------------------------------------
# TOKEN_PATH=cache_files/schwab_token.json

# -------------------------------------------
# GOOGLE SHEETS (REQUIRED for position tracking)
# The sheet ID is in the URL:
# docs.google.com/spreadsheets/d/<SHEET_ID>/edit
# -------------------------------------------
GOOGLE_SHEET_ID=your_google_sheet_id_here

# -------------------------------------------
# GROK AI / xAI (REQUIRED for AI analysis)
# Get your key at https://console.x.ai
# -------------------------------------------
XAI_API_KEY=your_xai_api_key_here

# -------------------------------------------
# TRADING PARAMETERS (OPTIONAL — has defaults)
# -------------------------------------------
# Total cash allocated for the wheel strategy
WHEEL_CAPITAL=25000

# Max number of concurrent positions
MAX_POSITIONS=5

# Max percentage of WHEEL_CAPITAL per single trade (0.20 = 20%)
MAX_PER_TRADE_PCT=0.20

# Total brokerage account size (used for risk/allocation display)
ACCOUNT_CAPITAL=100000

# Hard cap per single trade in dollars
MAX_CAPITAL_PER_TRADE=45000

# -------------------------------------------
# TELEGRAM NOTIFICATIONS (OPTIONAL)
# Create a bot at https://t.me/BotFather and
# get your chat ID from @userinfobot.
# -------------------------------------------
# PAPER_TRADE_MONITOR_TELEGRAM_TOKEN=your_telegram_bot_token
# PAPER_TRADE_MONITOR_CHAT_ID=your_chat_id
# TELEGRAM_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# SIMPLE_OPTIONS_SCANNER_TELEGRAM_TOKEN=your_telegram_bot_token
# COVERED_CALL_TELEGRAM_TOKEN=your_telegram_bot_token
# DIVIDEND_TRACKER_TELEGRAM_TOKEN=your_telegram_bot_token

# -------------------------------------------
# ADDITIONAL DATA SOURCES (OPTIONAL)
# -------------------------------------------
# EODHD API for supplemental market data
# EODHD_API_KEY=your_eodhd_api_key
